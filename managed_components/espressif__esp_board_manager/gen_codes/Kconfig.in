menu "Peripheral Support"

config ESP_BOARD_PERIPH_ADC_SUPPORT
    bool "Peripheral 'adc' support"
    help
        Enable adc peripheral support.
        This option enables the adc peripheral driver.
        The driver is located at: peripherals/periph_adc

